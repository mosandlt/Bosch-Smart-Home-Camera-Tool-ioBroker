{
  "name": "iobroker.bosch-smart-home-camera",
  "version": "0.1.0",
  "description": "ioBroker adapter for Bosch Smart Home Cameras (Eyes Outdoor/Indoor, 360°, Gen2 Indoor II/Outdoor II)",
  "author": {
    "name": "mosandlt",
    "email": "10558666+mosandlt@users.noreply.github.com"
  },
  "homepage": "https://github.com/mosandlt/ioBroker.bosch-smart-home-camera",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "iobroker",
    "adapter",
    "bosch",
    "smart-home",
    "camera"
  ],
  "main": "build/main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "npm run test:js && npm run test:package",
    "test:js": "TS_NODE_TRANSPILE_ONLY=true TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' mocha --config test/.mocharc.yml",
    "test:package": "mocha test/package.js --exit",
    "test:integration": "mocha test/integration.js --exit",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.2",
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "@iobroker/adapter-dev": "^1.3.0",
    "@iobroker/testing": "^4.1.3",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/sinon": "^17.0.4",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "chai": "^4.5.0",
    "eslint": "^9.24.0",
    "mocha": "^11.1.0",
    "sinon": "^19.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mosandlt/ioBroker.bosch-smart-home-camera.git"
  },
  "bugs": {
    "url": "https://github.com/mosandlt/ioBroker.bosch-smart-home-camera/issues"
  }
}
